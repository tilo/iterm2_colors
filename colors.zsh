iterm_apply_for_pwd() {
  [[ "$TERM_PROGRAM" == "iTerm.app" ]] || return   # no-op outside iTerm2
  local rel="${PWD#$HOME/}"
  local token=default
  case "$rel" in
    Work_*|GitHub_*)
      token="${rel#*_}"       # strip "Work_"/"GitHub_"
      token="${token%%/*}"    # strip "/whatever/after"
      token="${token:l}"      # lowercase
      ;;
  esac
  printf '%s' "${_ITERM_PAYLOAD[$token]:-$_ITERM_PAYLOAD[default]}"
}
autoload -U add-zsh-hook
add-zsh-hook chpwd iterm_apply_for_pwd
iterm_apply_for_pwd
